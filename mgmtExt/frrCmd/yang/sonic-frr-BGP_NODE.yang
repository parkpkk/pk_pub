
module sonic-frr-BGP_NODE {
    namespace "http://github.com/sonic-net/frr/sonic-frr-BGP_NODE";
    prefix frr-BGP_NODE;
    yang-version 1.1;

    import ietf-inet-types {
        prefix inet;
    }

    organization
        "SONiC";

    contact
        "SONiC";

    description
        "SONIC frr-BGP_NODE FRR YANG";

    revision 2024-12-23 {
        description
            "Initial revision.";
    }
    container sonic-frr-BGP_NODE {
        container BGP_NODE {
            list VRF-POLICY {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf VRF_NAME {
                    type string;
                }                  //NAME
            }
            list VNC {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf nve-group {
                    type enumeration {
                        enum nve-group;
                    }
                }                  //nve-group
                leaf GROUP_NAME {
                    type string;
                }                  //NAME
                leaf l2-group {
                    type enumeration {
                        enum l2-group;
                    }
                }                  //l2-group
                leaf export {
                    type enumeration {
                        enum export;
                    }
                }                  //export
                leaf EXPORT_CHOICE_CASE {
                    type enumeration {
                        enum bgp;
                        enum zebra;
                    }
                }                  //<bgp|zebra> ['Export to BGP', 'Export to Zebra (experimental)']
                leaf route-map {
                    type enumeration {
                        enum route-map;
                    }
                }                  //route-map
                leaf ROUTE_MAP_NAME {
                    type string;
                }                  //NAME
                leaf mode {
                    type enumeration {
                        enum mode;
                    }
                }                  //mode
                leaf MODE_CHOICE_CASE {
                    type enumeration {
                        enum group-nve;
                        enum ce;
                        enum none;
                        enum registering-nve;
                    }
                }                  //<group-nve|ce|none|registering-nve> ['Export routes with nve-group next-hops', 'Export routes with NVE connected router next-hops', 'Disable export', 'Export routes with registering NVE as next-hop']
                leaf group-nve_group {
                    type enumeration {
                        enum group-nve_group;
                    }
                }                  //group
                leaf REDISTRIBUTE_IP {
                    type enumeration {
                        enum ipv4;
                        enum ipv6;
                    }
                }                  //<ipv4|ipv6> ['IPv4 prefixes', 'IPv6 prefixes']
                leaf prefix-list {
                    type enumeration {
                        enum prefix-list;
                    }
                }                  //prefix-list
                leaf PREFIX_LIST_NAME {
                    type string;
                }                  //NAME
                leaf group-nve_no_group {
                    type enumeration {
                        enum group-nve_no_group;
                    }
                }                  //group
                leaf defaults {
                    type enumeration {
                        enum defaults;
                    }
                }                  //defaults
            }
            list UPDATE-DELAY {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf MAX_DELAY_IN_SECONDS {
                    type int32;
                }                  //(0-3600)
                leaf ESTABLISH_WAIT_IN_SECONDS {
                    type int32;
                }                  //(1-3600)
            }
            list TIMERS {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf bgp {
                    type enumeration {
                        enum bgp;
                    }
                }                  //bgp
                leaf KEEPALIVE_INTERVAL {
                    type int32;
                }                  //(0-65535)
                leaf HOLDTIME {
                    type int32;
                }                  //(0-65535)
            }
            list TABLE-MAP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf NAME_OF_THE_ROUTE {
                    type string;
                }                  //WORD
            }
            list SEGMENT-ROUTING {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf srv6 {
                    type enumeration {
                        enum srv6;
                    }
                }                  //srv6
            }
            list RFP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf holddown-factor {
                    type enumeration {
                        enum holddown-factor;
                    }
                }                  //holddown-factor
                leaf PERCENTAGE_OF_REGISTRATION_LIFETIME {
                    type int32;
                }                  //(0-4294967295)
                leaf full-table-download {
                    type enumeration {
                        enum full-table-download;
                    }
                }                  //full-table-download
                leaf FULL-TABLE-DOWNLOAD_RESPONSE_FILTER_TOGGLE {
                    type enumeration {
                        enum on;
                        enum off;
                    }
                }                  //<on|off> ['Enable RFP full table download', 'Disable RFP full table download']
                leaf example-config-value {
                    type enumeration {
                        enum example-config-value;
                    }
                }                  //example-config-value
                leaf VALUE_TO_DISPLAY {
                    type string;
                }                  //VALUE
            }
            list QUIT {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list NO {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf vrf-policy {
                    type enumeration {
                        enum vrf-policy;
                    }
                }                  //vrf-policy
                leaf VRF_NAME {
                    type string;
                }                  //NAME
                leaf table-map {
                    type enumeration {
                        enum table-map;
                    }
                }                  //table-map
                leaf NAME_OF_THE_ROUTE {
                    type string;
                }                  //WORD
                leaf synchronization {
                    type enumeration {
                        enum synchronization;
                    }
                }                  //synchronization
                leaf rd {
                    type enumeration {
                        enum rd;
                    }
                }                  //rd
                leaf coalesce-time {
                    type enumeration {
                        enum coalesce-time;
                    }
                }                  //coalesce-time
                leaf SUBGROUP_COALESCE_TIMER_VALUE {
                    type int32;
                }                  //(0-4294967295)
                leaf auto-summary {
                    type enumeration {
                        enum auto-summary;
                    }
                }                  //auto-summary
                leaf write-quanta {
                    type enumeration {
                        enum write-quanta;
                    }
                }                  //write-quanta
                leaf NUMBER_OF_PACKETS {
                    type int32;
                }                  //(1-64)
                leaf read-quanta {
                    type enumeration {
                        enum read-quanta;
                    }
                }                  //read-quanta
            }
            list NEIGHBOR {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf INTERFACE_NAME_OR_NEIGHBOR {
                    type string;
                }                  //WORD
                leaf peer-group {
                    type enumeration {
                        enum peer-group;
                    }
                }                  //peer-group
                leaf PEER-GROUP_NAME {
                    type string;
                }                  //PGNAME
                leaf interface {
                    type enumeration {
                        enum interface;
                    }
                }                  //interface
                leaf interface_remote-as {
                    type enumeration {
                        enum interface_remote-as;
                    }
                }                  //remote-as
                leaf REMOTE-AS_BGP_PEER {
                    type union {
                        type int32;
                        type enumeration {
                        enum internal;
                        enum external;
                        }
                    }
                }                  //<(1-4294967295)|internal|external> ['AS number', 'Internal BGP peer', 'External BGP peer']
                leaf interface_peer-group {
                    type enumeration {
                        enum interface_peer-group;
                    }
                }                  //peer-group
                leaf update-source {
                    type enumeration {
                        enum update-source;
                    }
                }                  //update-source
                leaf UPDATE-SOURCE_IP_ADDRESS {
                    type union {
                        type inet:ipv4-address;
                        type inet:ipv6-address;
                        type string;
                    }
                }                  //<A.B.C.D|X:X::X:X|WORD> ['IPv4 address', 'IPv6 address', 'Interface name (requires zebra to be running)']
                leaf ttl-security_hops {
                    type enumeration {
                        enum ttl-security_hops;
                    }
                }                  //hops
                leaf NUMBER_OF_HOPS_TO {
                    type int32;
                }                  //(1-254)
                leaf timers_delayopen {
                    type enumeration {
                        enum timers_delayopen;
                    }
                }                  //delayopen
                leaf DELAYOPENTIME_TIMER_INTERVAL {
                    type int32;
                }                  //(1-240)
                leaf timers_connect {
                    type enumeration {
                        enum timers_connect;
                    }
                }                  //connect
                leaf CONNECT_TIMER {
                    type int32;
                }                  //(1-65535)
                leaf timers {
                    type enumeration {
                        enum timers;
                    }
                }                  //timers
                leaf delayopen {
                    type enumeration {
                        enum delayopen;
                    }
                }                  //delayopen
                leaf connect {
                    type enumeration {
                        enum connect;
                    }
                }                  //connect
                leaf KEEPALIVE_INTERVAL {
                    type int32;
                }                  //(0-65535)
                leaf HOLDTIME {
                    type int32;
                }                  //(0-65535)
                leaf tcp-mss {
                    type enumeration {
                        enum tcp-mss;
                    }
                }                  //tcp-mss
                leaf TCP_MSS_VALUE {
                    type int32;
                }                  //(1-65535)
                leaf strict-capability-match {
                    type enumeration {
                        enum strict-capability-match;
                    }
                }                  //strict-capability-match
                leaf solo {
                    type enumeration {
                        enum solo;
                    }
                }                  //solo
                leaf shutdown {
                    type enumeration {
                        enum shutdown;
                    }
                }                  //shutdown
                leaf shutdown_rtt {
                    type enumeration {
                        enum shutdown_rtt;
                    }
                }                  //rtt
                leaf ROUND-TRIP-TIME_IN_MILLISECONDS {
                    type int32;
                }                  //(1-65535)
                leaf count {
                    type enumeration {
                        enum count;
                    }
                }                  //count
                leaf THE_NUMBER_OF_KEEPALIVES {
                    type int32;
                }                  //(1-255)
                leaf shutdown_message {
                    type enumeration {
                        enum shutdown_message;
                    }
                }                  //message
                leaf-list MESSAGE {
                    type string;
                }                  //MSG...
                leaf sender-as-path-loop-detection {
                    type enumeration {
                        enum sender-as-path-loop-detection;
                    }
                }                  //sender-as-path-loop-detection
                leaf remote-as {
                    type enumeration {
                        enum remote-as;
                    }
                }                  //remote-as
                leaf port {
                    type enumeration {
                        enum port;
                    }
                }                  //port
                leaf TCP_PORT_NUMBER {
                    type int32;
                }                  //(0-65535)
                leaf path-attribute_discard {
                    type enumeration {
                        enum path-attribute_discard;
                    }
                }                  //discard
                leaf-list ATTRIBUTE_NUMBER {
                    type int32;
                }                  //(1-255)...
                leaf password {
                    type enumeration {
                        enum password;
                    }
                }                  //password
                leaf LIST {
                    type string;
                }                  //LINE
                leaf passive {
                    type enumeration {
                        enum passive;
                    }
                }                  //passive
                leaf override-capability {
                    type enumeration {
                        enum override-capability;
                    }
                }                  //override-capability
                leaf maximum-prefix-out {
                    type enumeration {
                        enum maximum-prefix-out;
                    }
                }                  //maximum-prefix-out
                leaf MAXIMUM_NO_OF_PREFIX {
                    type int32;
                }                  //(1-4294967295)
                leaf local-role {
                    type enumeration {
                        enum local-role;
                    }
                }                  //local-role
                leaf LOCAL-ROLE_CHOICE_CASE {
                    type enumeration {
                        enum provider;
                        enum rs-server;
                        enum rs-client;
                        enum customer;
                        enum peer;
                    }
                }                  //<provider|rs-server|rs-client|customer|peer> ['Providing transit', 'Route server', 'RS client', 'Using transit', 'Public/private peering']
                leaf strict-mode {
                    type enumeration {
                        enum strict-mode;
                    }
                }                  //strict-mode
                leaf local-as {
                    type enumeration {
                        enum local-as;
                    }
                }                  //local-as
                leaf AS_NUMBER_USED_AS {
                    type int32;
                }                  //(1-4294967295)
                leaf no-prepend {
                    type enumeration {
                        enum no-prepend;
                    }
                }                  //no-prepend
                leaf no-prepend_replace-as {
                    type enumeration {
                        enum no-prepend_replace-as;
                    }
                }                  //replace-as
                leaf graceful-restart-helper {
                    type enumeration {
                        enum graceful-restart-helper;
                    }
                }                  //graceful-restart-helper
                leaf graceful-restart-disable {
                    type enumeration {
                        enum graceful-restart-disable;
                    }
                }                  //graceful-restart-disable
                leaf graceful-restart {
                    type enumeration {
                        enum graceful-restart;
                    }
                }                  //graceful-restart
                leaf extended-optional-parameters {
                    type enumeration {
                        enum extended-optional-parameters;
                    }
                }                  //extended-optional-parameters
                leaf enforce-first-as {
                    type enumeration {
                        enum enforce-first-as;
                    }
                }                  //enforce-first-as
                leaf ebgp-multihop {
                    type enumeration {
                        enum ebgp-multihop;
                    }
                }                  //ebgp-multihop
                leaf MAXIMUM_HOP_COUNT {
                    type int32;
                }                  //(1-255)
                leaf dont-capability-negotiate {
                    type enumeration {
                        enum dont-capability-negotiate;
                    }
                }                  //dont-capability-negotiate
                leaf disable-link-bw-encoding-ieee {
                    type enumeration {
                        enum disable-link-bw-encoding-ieee;
                    }
                }                  //disable-link-bw-encoding-ieee
                leaf description {
                    type enumeration {
                        enum description;
                    }
                }                  //description
                leaf capability_extended-nexthop {
                    type enumeration {
                        enum capability_extended-nexthop;
                    }
                }                  //extended-nexthop
                leaf capability_dynamic {
                    type enumeration {
                        enum capability_dynamic;
                    }
                }                  //dynamic
                leaf bfd {
                    type enumeration {
                        enum bfd;
                    }
                }                  //bfd
                leaf bfd_profile {
                    type enumeration {
                        enum bfd_profile;
                    }
                }                  //profile
                leaf BFD_PROFILE_NAME {
                    type string;
                }                  //BFDPROF
                leaf profile {
                    type enumeration {
                        enum profile;
                    }
                }                  //profile
                leaf DETECT_MULTIPLIER {
                    type int32;
                }                  //(2-255)
                leaf REQUIRED_MIN_RECEIVE_INTERVAL {
                    type int32;
                }                  //(50-60000)
                leaf DESIRED_MIN_TRANSMIT_INTERVAL {
                    type int32;
                }                  //(50-60000)
                leaf check-control-plane-failure {
                    type enumeration {
                        enum check-control-plane-failure;
                    }
                }                  //check-control-plane-failure
                leaf advertisement-interval {
                    type enumeration {
                        enum advertisement-interval;
                    }
                }                  //advertisement-interval
                leaf TIME_IN_SECONDS {
                    type int32;
                }                  //(0-600)
                leaf EBGP_PEER_USING {
                    type enumeration {
                        enum disable-connected-check;
                        enum enforce-multihop;
                    }
                }                  //<disable-connected-check|enforce-multihop> ['one-hop away EBGP peer using loopback address', 'Enforce EBGP neighbors perform multihop']
                leaf graceful-shutdown {
                    type enumeration {
                        enum graceful-shutdown;
                    }
                }                  //graceful-shutdown
                leaf aigp {
                    type enumeration {
                        enum aigp;
                    }
                }                  //aigp
                leaf interface_v6only {
                    type enumeration {
                        enum interface_v6only;
                    }
                }                  //interface_v6only
                leaf interface_v6only_remote-as {
                    type enumeration {
                        enum interface_v6only_remote-as;
                    }
                }                  //remote-as
                leaf interface_v6only_peer-group {
                    type enumeration {
                        enum interface_v6only_peer-group;
                    }
                }                  //peer-group
                leaf IP_ADDRESS {
                    type union {
                        type inet:ipv4-address;
                        type inet:ipv6-address;
                    }
                }                  //<A.B.C.D|X:X::X:X> ['Neighbor address', 'Neighbor IPv6 address']
                leaf INTERFACE_NAME {
                    type string;
                }                  //WORD
            }
            list EXIT {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list END {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list DISTANCE {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf bgp {
                    type enumeration {
                        enum bgp;
                    }
                }                  //bgp
                leaf DISTANCE_FOR_ROUTES_EXTERNAL {
                    type int32;
                }                  //(1-255)
                leaf DISTANCE_FOR_ROUTES_INTERNAL {
                    type int32;
                }                  //(1-255)
                leaf DISTANCE_FOR_LOCAL_ROUTES {
                    type int32;
                }                  //(1-255)
                leaf ADMINISTRATIVE_DISTANCE {
                    type int32;
                }                  //(1-255)
                leaf IP_PREFIX {
                    type inet:ipv4-prefix;
                }                  //A.B.C.D/M
                leaf ACCESS_LIST_NAME {
                    type string;
                }                  //WORD
            }
            list COALESCE-TIME {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf SUBGROUP_COALESCE_TIMER_VALUE {
                    type int32;
                }                  //(0-4294967295)
            }
            list BMP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf targets {
                    type enumeration {
                        enum targets;
                    }
                }                  //targets
                leaf NAME_OF_THE_BMP {
                    type string;
                }                  //BMP
            }
            list BGP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf tcp-keepalive {
                    type enumeration {
                        enum tcp-keepalive;
                    }
                }                  //tcp-keepalive
                leaf TCP_KEEPALIVE_IDLE_TIME {
                    type int32;
                }                  //(1-65535)
                leaf TCP_KEEPALIVE_INTERVAL {
                    type int32;
                }                  //(1-65535)
                leaf TCP_KEEPALIVE_MAXIMUM_PROBES {
                    type int32;
                }                  //(1-30)
                leaf suppress-duplicates {
                    type enumeration {
                        enum suppress-duplicates;
                    }
                }                  //suppress-duplicates
                leaf router-id {
                    type enumeration {
                        enum router-id;
                    }
                }                  //router-id
                leaf MANUALLY_CONFIGURED_ROUTER_IDENTIFIER {
                    type inet:ipv4-address;
                }                  //A.B.C.D
                leaf reject-as-sets {
                    type enumeration {
                        enum reject-as-sets;
                    }
                }                  //reject-as-sets
                leaf minimum-holdtime {
                    type enumeration {
                        enum minimum-holdtime;
                    }
                }                  //minimum-holdtime
                leaf SECONDS {
                    type int32;
                }                  //(1-65535)
                leaf log-neighbor-changes {
                    type enumeration {
                        enum log-neighbor-changes;
                    }
                }                  //log-neighbor-changes
                leaf graceful-shutdown {
                    type enumeration {
                        enum graceful-shutdown;
                    }
                }                  //graceful-shutdown
                leaf graceful-restart-disable {
                    type enumeration {
                        enum graceful-restart-disable;
                    }
                }                  //graceful-restart-disable
                leaf fast-external-failover {
                    type enumeration {
                        enum fast-external-failover;
                    }
                }                  //fast-external-failover
                leaf fast-convergence {
                    type enumeration {
                        enum fast-convergence;
                    }
                }                  //fast-convergence
                leaf ebgp-requires-policy {
                    type enumeration {
                        enum ebgp-requires-policy;
                    }
                }                  //ebgp-requires-policy
                leaf disable-ebgp-connected-route-check {
                    type enumeration {
                        enum disable-ebgp-connected-route-check;
                    }
                }                  //disable-ebgp-connected-route-check
                leaf deterministic-med {
                    type enumeration {
                        enum deterministic-med;
                    }
                }                  //deterministic-med
                leaf cluster-id {
                    type enumeration {
                        enum cluster-id;
                    }
                }                  //cluster-id
                leaf CLUSTER-ID_CHOICE_CASE {
                    type union {
                        type inet:ipv4-address;
                        type int32;
                    }
                }                  //<A.B.C.D|(1-4294967295)> ['Route-Reflector Cluster-id in IP address format', 'Route-Reflector Cluster-id as 32 bit quantity']
                leaf always-compare-med {
                    type enumeration {
                        enum always-compare-med;
                    }
                }                  //always-compare-med
                leaf suppress-fib-pending {
                    type enumeration {
                        enum suppress-fib-pending;
                    }
                }                  //suppress-fib-pending
                leaf hard-administrative-reset {
                    type enumeration {
                        enum hard-administrative-reset;
                    }
                }                  //hard-administrative-reset
                leaf allow-martian-nexthop {
                    type enumeration {
                        enum allow-martian-nexthop;
                    }
                }                  //allow-martian-nexthop
            }
            list ADDRESS-FAMILY {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf evpn {
                    type enumeration {
                        enum evpn;
                    }
                }                  //evpn
            }
            list WRITE-QUANTA {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf NUMBER_OF_PACKETS {
                    type int32;
                }                  //(1-64)
            }
            list READ-QUANTA {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf NUMBER_OF_PACKETS {
                    type int32;
                }                  //(1-10)
            }
            list NETWORK {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf IP_PREFIX {
                    type inet:ipv4-prefix;
                }                  //A.B.C.D/M
                leaf route-map {
                    type enumeration {
                        enum route-map;
                    }
                }                  //route-map
                leaf NAME_OF_THE_ROUTE {
                    type string;
                }                  //RMAP_NAME
                leaf label-index {
                    type enumeration {
                        enum label-index;
                    }
                }                  //label-index
                leaf LABEL_INDEX_VALUE {
                    type int32;
                }                  //(0-1048560)
                leaf backdoor {
                    type enumeration {
                        enum backdoor;
                    }
                }                  //backdoor
                leaf NETWORK_NUMBER {
                    type inet:ipv4-address;
                }                  //A.B.C.D
                leaf mask {
                    type enumeration {
                        enum mask;
                    }
                }                  //mask
                leaf NETWORK_MASK {
                    type inet:ipv4-address;
                }                  //A.B.C.D
            }
            list AGGREGATE-ADDRESS {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf IP_PREFIX {
                    type inet:ipv4-prefix;
                }                  //A.B.C.D/M
                leaf as-set {
                    type enumeration {
                        enum as-set;
                    }
                }                  //as-set
                leaf summary-only {
                    type enumeration {
                        enum summary-only;
                    }
                }                  //summary-only
                leaf route-map {
                    type enumeration {
                        enum route-map;
                    }
                }                  //route-map
                leaf ROUTE_MAP_NAME {
                    type string;
                }                  //RMAP_NAME
                leaf origin {
                    type enumeration {
                        enum origin;
                    }
                }                  //origin
                leaf ORIGIN_CHOICE_CASE {
                    type enumeration {
                        enum egp;
                        enum igp;
                        enum incomplete;
                    }
                }                  //<egp|igp|incomplete> ['Remote EGP', 'Local IGP', 'Unknown heritage']
                leaf matching-MED-only {
                    type enumeration {
                        enum matching-MED-only;
                    }
                }                  //matching-MED-only
                leaf suppress-map {
                    type enumeration {
                        enum suppress-map;
                    }
                }                  //suppress-map
                leaf ROUTE_MAP_WITH_THE {
                    type string;
                }                  //RMAP_NAME
                leaf AGGREGATE_ADDRESS {
                    type inet:ipv4-address;
                }                  //A.B.C.D
                leaf AGGREGATE_MASK {
                    type inet:ipv4-address;
                }                  //A.B.C.D
            }
            list OUTPUT {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf file {
                    type enumeration {
                        enum file;
                    }
                }                  //file
                leaf PATH_TO_DUMP_OUTPUT {
                    type string;
                }                  //FILE
            }
            list LIST {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf permutations {
                    type enumeration {
                        enum permutations;
                    }
                }                  //permutations
            }
            list FIND {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf-list SEARCH_PATTERN {
                    type string;
                }                  //REGEX...
            }
            list VNC_REDISTRIBUTE {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf nve-group {
                    type enumeration {
                        enum nve-group;
                    }
                }                  //nve-group
                leaf GROUP_NAME {
                    type string;
                }                  //NAME
                leaf mode {
                    type enumeration {
                        enum mode;
                    }
                }                  //mode
                leaf MODE_CHOICE_CASE {
                    type enumeration {
                        enum nve-group;
