                leaf PREFIX {
                    type string; 
                } 
                leaf broadcast {
                    type enumeration {
                        enum broadcast;
                    }
                }                  //broadcast
                leaf non-broadcast {
                    type enumeration {
                        enum non-broadcast;
                    }
                }                  //non-broadcast
                leaf point-to-multipoint {
