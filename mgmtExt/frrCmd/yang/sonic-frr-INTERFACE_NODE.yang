                    }
                }                  //point-to-point
            }
            list ISIS_HELLO {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf padding {
                    type enumeration {
                        enum padding;
                    }
                }                  //padding
            }
            list IPV6_ROUTER {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf openfabric {
                    type enumeration {
