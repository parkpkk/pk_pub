
module sonic-frr-INTERFACE_NODE {
    namespace "http://github.com/sonic-net/frr/sonic-frr-INTERFACE_NODE";
    prefix frr-INTERFACE_NODE;
    yang-version 1.1;

    import ietf-inet-types {
        prefix inet;
    }

    organization
        "SONiC";

    contact
        "SONiC";

    description
        "SONIC frr-INTERFACE_NODE FRR YANG";

    revision 2024-12-23 {
        description
            "Initial revision.";
    }
    container sonic-frr-INTERFACE_NODE {
        container INTERFACE_NODE {
            list OUTPUT {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf file {
                    type enumeration {
                        enum file;
                    }
                }                  //file
                leaf PATH_TO_DUMP_OUTPUT {
                    type string;
                }                  //FILE
            }
            list NO {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf vrrp {
                    type enumeration {
                        enum vrrp;
                    }
                }                  //vrrp
                leaf VIRTUAL_ROUTER_ID {
                    type int32;
                }                  //(1-255)
                leaf priority {
                    type enumeration {
                        enum priority;
                    }
                }                  //priority
                leaf PRIORITY_VALUE {
                    type int32;
                }                  //(1-254)
                leaf advertisement-interval {
                    type enumeration {
                        enum advertisement-interval;
                    }
                }                  //advertisement-interval
                leaf ADVERTISEMENT_INTERVAL_IN_MILLISECONDS {
                    type int32;
                }                  //(10-40950)
                leaf shutdown {
                    type enumeration {
                        enum shutdown;
                    }
                }                  //shutdown
                leaf preempt {
                    type enumeration {
                        enum preempt;
                    }
                }                  //preempt
                leaf ipv6 {
                    type enumeration {
                        enum ipv6;
                    }
                }                  //ipv6
                leaf VIRTUAL_ROUTER_IP_ADDRESS {
                    type inet:ipv6-address;
                }                  //X:X::X:X
                leaf ip {
                    type enumeration {
                        enum ip;
                    }
                }                  //ip
                leaf checksum-with-ipv4-pseudoheader {
                    type enumeration {
                        enum checksum-with-ipv4-pseudoheader;
                    }
                }                  //checksum-with-ipv4-pseudoheader
                leaf version {
                    type enumeration {
                        enum version;
                    }
                }                  //version
                leaf VRRP_PROTOCOL_VERSION {
                    type int32;
                }                  //(2-3)
                leaf ptm-enable {
                    type enumeration {
                        enum ptm-enable;
                    }
                }                  //ptm-enable
                leaf multicast {
                    type enumeration {
                        enum multicast;
                    }
                }                  //multicast
                leaf link-detect {
                    type enumeration {
                        enum link-detect;
                    }
                }                  //link-detect
                leaf pbr-policy {
                    type enumeration {
                        enum pbr-policy;
                    }
                }                  //pbr-policy
                leaf NAME_OF_THE_PBR-MAP {
                    type string;
                }                  //PBRMAP
            }
            list LIST {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf permutations {
                    type enumeration {
                        enum permutations;
                    }
                }                  //permutations
            }
            list FIND {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf-list SEARCH_PATTERN {
                    type string;
                }                  //REGEX...
            }
            list VRRP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf VIRTUAL_ROUTER_ID {
                    type int32;
                }                  //(1-255)
                leaf priority {
                    type enumeration {
                        enum priority;
                    }
                }                  //priority
                leaf PRIORITY_VALUE {
                    type int32;
                }                  //(1-254)
                leaf advertisement-interval {
                    type enumeration {
                        enum advertisement-interval;
                    }
                }                  //advertisement-interval
                leaf ADVERTISEMENT_INTERVAL_IN_MILLISECONDS {
                    type int32;
                }                  //(10-40950)
                leaf shutdown {
                    type enumeration {
                        enum shutdown;
                    }
                }                  //shutdown
                leaf preempt {
                    type enumeration {
                        enum preempt;
                    }
                }                  //preempt
                leaf ipv6 {
                    type enumeration {
                        enum ipv6;
                    }
                }                  //ipv6
                leaf VIRTUAL_ROUTER_IP_ADDRESS {
                    type inet:ipv6-address;
                }                  //X:X::X:X
                leaf ip {
                    type enumeration {
                        enum ip;
                    }
                }                  //ip
                leaf checksum-with-ipv4-pseudoheader {
                    type enumeration {
                        enum checksum-with-ipv4-pseudoheader;
                    }
                }                  //checksum-with-ipv4-pseudoheader
                leaf version {
                    type enumeration {
                        enum version;
                    }
                }                  //version
                leaf VRRP_PROTOCOL_VERSION {
                    type int32;
                }                  //(2-3)
            }
            list TUNNEL {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf source {
                    type enumeration {
                        enum source;
                    }
                }                  //source
                leaf INTERFACE_NAME {
                    type string;
                }                  //INTERFACE
            }
            list SHUTDOWN {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list QUIT {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list PTM-ENABLE {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list OSPF {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf transmit-delay {
                    type enumeration {
                        enum transmit-delay;
                    }
                }                  //transmit-delay
                leaf SECONDS {
                    type int32;
                }                  //(1-65535)
                leaf ADDRESS_OF_INTERFACE {
                    type inet:ipv4-address;
                }                  //A.B.C.D
                leaf retransmit-interval {
                    type enumeration {
                        enum retransmit-interval;
                    }
                }                  //retransmit-interval
                leaf priority {
                    type enumeration {
                        enum priority;
                    }
                }                  //priority
                leaf COST_VALUE {
                    type int32;
                }                  //(0-255)
                leaf network {
                    type enumeration {
                        enum network;
                    }
                }                  //network
                leaf NETWORK_OSPF_NETWORK_TYPE {
                    type enumeration {
                        enum broadcast;
                        enum non-broadcast;
                        enum point-to-multipoint;
                        enum point-to-point;
                    }
                }                  //<broadcast|non-broadcast|point-to-multipoint|point-to-point> ['Specify OSPF broadcast multi-access network', 'Specify OSPF NBMA network', 'Specify OSPF point-to-multipoint network', 'Specify OSPF point-to-point network']
                leaf message-digest-key {
                    type enumeration {
                        enum message-digest-key;
                    }
                }                  //message-digest-key
                leaf KEY_ID {
                    type int32;
                }                  //(1-255)
                leaf md5 {
                    type enumeration {
                        enum md5;
                    }
                }                  //md5
                leaf THE_OSPF_PASSWORD {
                    type string;
                }                  //KEY
                leaf hello-interval {
                    type enumeration {
                        enum hello-interval;
                    }
                }                  //hello-interval
                leaf dead-interval {
                    type enumeration {
                        enum dead-interval;
                    }
                }                  //dead-interval
                leaf cost {
                    type enumeration {
                        enum cost;
                    }
                }                  //cost
                leaf COST {
                    type int32;
                }                  //(1-65535)
                leaf authentication-key {
                    type enumeration {
                        enum authentication-key;
                    }
                }                  //authentication-key
            }
            list OPENFABRIC {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf topology {
                    type enumeration {
                        enum topology;
                    }
                }                  //topology
                leaf ISIS_MT_DESCRIPTIONS {
                    type string;
                }                  //ISIS_MT_NAMES
                leaf psnp-interval {
                    type enumeration {
                        enum psnp-interval;
                    }
                }                  //psnp-interval
                leaf PSNP_INTERVAL_VALUE {
                    type int32;
                }                  //(1-120)
                leaf password {
                    type enumeration {
                        enum password;
                    }
                }                  //password
                leaf PASSWORD_AUTHENTICATION_METHOD {
                    type enumeration {
                        enum md5;
                        enum clear;
                    }
                }                  //<md5|clear> ['HMAC-MD5 authentication', 'Cleartext password']
                leaf CIRCUIT_PASSWORD {
                    type string;
                }                  //WORD
                leaf passive {
                    type enumeration {
                        enum passive;
                    }
                }                  //passive
                leaf metric {
                    type enumeration {
                        enum metric;
                    }
                }                  //metric
                leaf DEFAULT_METRIC_VALUE {
                    type int32;
                }                  //(0-16777215)
                leaf hello-multiplier {
                    type enumeration {
                        enum hello-multiplier;
                    }
                }                  //hello-multiplier
                leaf HELLO_MULTIPLIER_VALUE {
                    type int32;
                }                  //(2-100)
                leaf hello-interval {
                    type enumeration {
                        enum hello-interval;
                    }
                }                  //hello-interval
                leaf HOLDTIME_1_SECONDS_INTERVAL {
                    type int32;
                }                  //(1-600)
                leaf csnp-interval {
                    type enumeration {
                        enum csnp-interval;
                    }
                }                  //csnp-interval
                leaf CSNP_INTERVAL_VALUE {
                    type int32;
                }                  //(1-600)
                leaf bfd {
                    type enumeration {
                        enum bfd;
                    }
                }                  //bfd
            }
            list MULTICAST {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list LINK-PARAMS {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list LINK-DETECT {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list ISIS {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf psnp-interval {
                    type enumeration {
                        enum psnp-interval;
                    }
                }                  //psnp-interval
                leaf PSNP_INTERVAL_VALUE {
                    type int32;
                }                  //(1-120)
                leaf level-1 {
                    type enumeration {
                        enum level-1;
                    }
                }                  //level-1
                leaf level-2 {
                    type enumeration {
                        enum level-2;
                    }
                }                  //level-2
                leaf priority {
                    type enumeration {
                        enum priority;
                    }
                }                  //priority
                leaf PRIORITY_VALUE {
                    type int32;
                }                  //(0-127)
                leaf password {
                    type enumeration {
                        enum password;
                    }
                }                  //password
                leaf PASSWORD_AUTHENTICATION_METHOD {
                    type enumeration {
                        enum md5;
                        enum clear;
                    }
                }                  //<md5|clear> ['HMAC-MD5 authentication', 'Cleartext password']
                leaf CIRCUIT_PASSWORD {
                    type string;
                }                  //WORD
                leaf passive {
                    type enumeration {
                        enum passive;
                    }
                }                  //passive
                leaf csnp-interval {
                    type enumeration {
                        enum csnp-interval;
                    }
                }                  //csnp-interval
                leaf CSNP_INTERVAL_VALUE {
                    type int32;
                }                  //(1-600)
                leaf circuit-type {
                    type enumeration {
                        enum circuit-type;
                    }
                }                  //circuit-type
                leaf CIRCUIT-TYPE_ISIS_ROUTER_LEVEL {
                    type enumeration {
                        enum level-1;
                        enum level-1-2;
                        enum level-2-only;
                    }
                }                  //<level-1|level-1-2|level-2-only> ['Level-1 only adjacencies are formed', 'Level-1-2 adjacencies are formed', 'Level-2 only adjacencies are formed']
                leaf three-way-handshake {
                    type enumeration {
                        enum three-way-handshake;
                    }
                }                  //three-way-handshake
            }
            list IPV6 {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf mroute {
                    type enumeration {
                        enum mroute;
                    }
                }                  //mroute
                leaf OUTGOING_INTERFACE_NAME {
                    type string;
                }                  //INTERFACE
                leaf GROUP_ADDRESS {
                    type inet:ipv6-address;
                }                  //X:X::X:X
                leaf SOURCE_ADDRESS {
                    type inet:ipv6-address;
                }                  //X:X::X:X
                leaf address {
                    type enumeration {
                        enum address;
                    }
                }                  //address
                leaf IPV6_ADDRESS_ {
                    type inet:ipv6-prefix;
                }                  //X:X::X:X/M
            }
            list IP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf mroute {
                    type enumeration {
                        enum mroute;
                    }
                }                  //mroute
                leaf OUTGOING_INTERFACE_NAME {
                    type string;
                }                  //INTERFACE
                leaf GROUP_ADDRESS {
                    type inet:ipv4-address;
                }                  //A.B.C.D
                leaf SOURCE_ADDRESS {
                    type inet:ipv4-address;
                }                  //A.B.C.D
            }
            list EXIT {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list END {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
            }
            list EIGRP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf bandwidth {
                    type enumeration {
                        enum bandwidth;
                    }
                }                  //bandwidth
                leaf BANDWIDTH_IN_KILOBITS {
                    type int32;
                }                  //(1-10000000)
            }
            list DELAY {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf THROUGHPUT_DELAY {
                    type int32;
                }                  //(1-16777215)
            }
            list BANDWIDTH {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf BANDWIDTH_IN_MEGABITS {
                    type int32;
                }                  //(1-100000)
            }
            list PBR-POLICY {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf NAME_OF_THE_PBR-MAP {
                    type string;
                }                  //PBRMAP
            }
            list MPLS {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf enable {
                    type enumeration {
                        enum enable;
                    }
                }                  //enable
            }
            list BABEL {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf wireless {
                    type enumeration {
                        enum wireless;
                    }
                }                  //wireless
                leaf wired {
                    type enumeration {
                        enum wired;
                    }
                }                  //wired
                leaf update-interval {
                    type enumeration {
                        enum update-interval;
                    }
                }                  //update-interval
                leaf MILLISECONDS {
                    type int32;
                }                  //(20-655340)
                leaf split-horizon {
                    type enumeration {
                        enum split-horizon;
                    }
                }                  //split-horizon
                leaf rxcost {
                    type enumeration {
                        enum rxcost;
                    }
                }                  //rxcost
                leaf UNITS {
                    type int32;
                }                  //(1-65534)
                leaf rtt-min {
                    type enumeration {
                        enum rtt-min;
                    }
                }                  //rtt-min
                leaf rtt-max {
                    type enumeration {
                        enum rtt-max;
                    }
                }                  //rtt-max
                leaf rtt-decay {
                    type enumeration {
                        enum rtt-decay;
                    }
                }                  //rtt-decay
                leaf UNITS_OF_1256 {
                    type int32;
                }                  //(1-256)
                leaf max-rtt-penalty {
                    type enumeration {
                        enum max-rtt-penalty;
                    }
                }                  //max-rtt-penalty
                leaf hello-interval {
                    type enumeration {
                        enum hello-interval;
                    }
                }                  //hello-interval
                leaf enable-timestamps {
                    type enumeration {
                        enum enable-timestamps;
                    }
                }                  //enable-timestamps
                leaf channel {
                    type enumeration {
                        enum channel;
                    }
                }                  //channel
                leaf CHANNEL_CHOICE_CASE {
                    type union {
                        type int32;
                        type enumeration {
                        enum interfering;
                        enum noninterfering;
                        }
                    }
                }                  //<(1-254)|interfering|noninterfering> ['Number', 'Mark channel as interfering', 'Mark channel as noninterfering']
            }
            list NO_TUNNEL {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf source {
                    type enumeration {
                        enum source;
                    }
                }                  //source
                leaf protection {
                    type enumeration {
                        enum protection;
                    }
                }                  //protection
            }
            list NO_OSPF {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf message-digest-key {
                    type enumeration {
                        enum message-digest-key;
                    }
                }                  //message-digest-key
                leaf KEY_ID {
                    type int32;
                }                  //(1-255)
                leaf md5 {
                    type enumeration {
                        enum md5;
                    }
                }                  //md5
                leaf THE_OSPF_PASSWORD {
                    type string;
                }                  //KEY
                leaf ADDRESS_OF_INTERFACE {
                    type inet:ipv4-address;
                }                  //A.B.C.D
            }
            list NO_OPENFABRIC {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf topology {
                    type enumeration {
                        enum topology;
                    }
                }                  //topology
                leaf ISIS_MT_DESCRIPTIONS {
                    type string;
                }                  //ISIS_MT_NAMES
                leaf passive {
                    type enumeration {
                        enum passive;
                    }
                }                  //passive
                leaf bfd {
                    type enumeration {
                        enum bfd;
                    }
                }                  //bfd
            }
            list NO_ISIS {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf passive {
                    type enumeration {
                        enum passive;
                    }
                }                  //passive
                leaf three-way-handshake {
                    type enumeration {
                        enum three-way-handshake;
                    }
                }                  //three-way-handshake
            }
            list NO_IPV6 {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf mroute {
                    type enumeration {
                        enum mroute;
                    }
                }                  //mroute
                leaf OUTGOING_INTERFACE_NAME {
                    type string;
                }                  //INTERFACE
                leaf GROUP_ADDRESS {
                    type inet:ipv6-address;
                }                  //X:X::X:X
                leaf SOURCE_ADDRESS {
                    type inet:ipv6-address;
                }                  //X:X::X:X
                leaf address {
                    type enumeration {
                        enum address;
                    }
                }                  //address
                leaf IPV6_ADDRESS_ {
                    type inet:ipv6-prefix;
                }                  //X:X::X:X/M
            }
            list NO_IP {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf mroute {
                    type enumeration {
                        enum mroute;
                    }
                }                  //mroute
                leaf OUTGOING_INTERFACE_NAME {
                    type string;
                }                  //INTERFACE
                leaf GROUP_ADDRESS {
                    type inet:ipv4-address;
                }                  //A.B.C.D
                leaf SOURCE_ADDRESS {
                    type inet:ipv4-address;
                }                  //A.B.C.D
            }
            list NO_DELAY {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf THROUGHPUT_DELAY {
                    type int32;
                }                  //(1-16777215)
            }
            list NO_BANDWIDTH {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf BANDWIDTH_IN_MEGABITS {
                    type int32;
                }                  //(1-100000)
            }
            list NO_MPLS {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf enable {
                    type enumeration {
                        enum enable;
                    }
                }                  //enable
            }
            list NO_BABEL {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf wireless {
                    type enumeration {
                        enum wireless;
                    }
                }                  //wireless
                leaf wired {
                    type enumeration {
                        enum wired;
                    }
                }                  //wired
                leaf update-interval {
                    type enumeration {
                        enum update-interval;
                    }
                }                  //update-interval
                leaf MILLISECONDS {
                    type int32;
                }                  //(20-655340)
                leaf split-horizon {
                    type enumeration {
                        enum split-horizon;
                    }
                }                  //split-horizon
                leaf rxcost {
                    type enumeration {
                        enum rxcost;
                    }
                }                  //rxcost
                leaf UNITS {
                    type int32;
                }                  //(1-65534)
                leaf rtt-min {
                    type enumeration {
                        enum rtt-min;
                    }
                }                  //rtt-min
                leaf rtt-max {
                    type enumeration {
                        enum rtt-max;
                    }
                }                  //rtt-max
                leaf rtt-decay {
                    type enumeration {
                        enum rtt-decay;
                    }
                }                  //rtt-decay
                leaf UNITS_OF_1256 {
                    type int32;
                }                  //(1-256)
                leaf max-rtt-penalty {
                    type enumeration {
                        enum max-rtt-penalty;
                    }
                }                  //max-rtt-penalty
                leaf hello-interval {
                    type enumeration {
                        enum hello-interval;
                    }
                }                  //hello-interval
                leaf enable-timestamps {
                    type enumeration {
                        enum enable-timestamps;
                    }
                }                  //enable-timestamps
                leaf channel {
                    type enumeration {
                        enum channel;
                    }
                }                  //channel
                leaf CHANNEL_CHOICE_CASE {
                    type union {
                        type int32;
                        type enumeration {
                        enum interfering;
                        enum noninterfering;
                        }
                    }
                }                  //<(1-254)|interfering|noninterfering> ['Number', 'Mark channel as interfering', 'Mark channel as noninterfering']
            }
            list ISIS_TOPOLOGY {
                key "PREFIX";
                leaf PREFIX {
                    type string; 
                } 
                leaf ISIS_MT_DESCRIPTIONS {
                    type string;
                }                  //ISIS_MT_NAMES
                leaf CHOICE_CASE {
                    type enumeration {
                        enum standard;
                        enum ipv4-unicast;
                        enum ipv4-mgmt;
                        enum ipv6-unicast;
                        enum ipv4-multicast;
                        enum ipv6-multicast;
                        enum ipv6-mgmt;
                        enum ipv6-dstsrc;
                    }
                }                  //<standard|ipv4-unicast|ipv4-mgmt|ipv6-unicast|ipv4-multicast|ipv6-multicast|ipv6-mgmt|ipv6-dstsrc> ['Standard topology', 'IPv4 unicast topology', 'IPv4 management topology', 'IPv6 unicast topology', 'IPv4 multicast topology', 'IPv6 multicast topology', 'IPv6 management topology', 'IPv6 dst-src topology']
            }
            list ISIS_METRIC {
                key "PREFIX";
                leaf PREFIX {
