                                                            "desc": [
                                                                "Gateway IP ( A.B.C.D )",
                                                                "Gateway IPv6 ( X:X::X:X )"
                                                            ],
                                                            "<cr>": {
                                                                "desc": [
                                                                    "end_cmd"
                                                                ]
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            },
