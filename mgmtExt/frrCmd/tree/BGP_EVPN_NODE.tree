                                                "desc": [
                                                    "Ethernet Segment Identifier"
                                                ],
                                                "WORD": {
                                                    "desc": [
                                                        "ESI value ( 00:11:22:33:44:55:66:77:88:99 format)"
                                                    ],
                                                    "gwip": {
                                                        "desc": [
                                                            "Gateway IP"
                                                        ],
