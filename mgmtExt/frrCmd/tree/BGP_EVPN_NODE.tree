                            "end_cmd"
                        ]
                    }
                }
            },
            "route-target": {
                "desc": [
                    "Route Target"
                ],
                "<both|import|export>": {
                    "desc": [
                        "import and export",
                        "import",
                        "export"
                    ],
                    "auto": {
                        "desc": [
                            "Automatically derive route target"
                        ],
                        "<cr>": {
                            "desc": [
                                "end_cmd"
                            ]
                        }
                    },
                    "RTLIST...": {
                        "desc": [
                            "Space separated route target list (A.B.C.D:MN|EF:OPQR|GHJK:MN)"
                        ],
                        "<cr>": {
                            "desc": [
                                "end_cmd"
                            ]
                        }
                    }
                }
            },
            "rd": {
                "desc": [
                    "Route Distinguisher"
                ],
                "ASN:NN_OR_IP-ADDRESS:NN": {
                    "desc": [
                        "ASN:XX or A.B.C.D:XX"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "network": {
                "desc": [
                    "Specify a network to announce via BGP"
                ],
                "<A.B.C.D/M|X:X::X:X/M>": {
                    "desc": [
                        "IP prefix",
                        "IPv6 prefix"
                    ],
                    "rd": {
                        "desc": [
                            "Specify Route Distinguisher"
                        ],
                        "ASN:NN_OR_IP-ADDRESS:NN": {
                            "desc": [
                                "VPN Route Distinguisher"
                            ],
                            "ethtag": {
                                "desc": [
                                    "Ethernet Tag"
                                ],
                                "WORD": {
                                    "desc": [
                                        "Ethernet Tag Value"
                                    ],
                                    "label": {
                                        "desc": [
                                            "BGP label"
                                        ],
                                        "WORD": {
                                            "desc": [
                                                "label value"
                                            ],
