                "desc": [
                    "end_cmd"
                ]
            }
        },
        "strip": {
            "desc": [
                "Strip the vlan tags from frame"
            ],
            "vlan": {
                "desc": [
                    "Strip any inner vlan tag"
                ],
                "<cr>": {
