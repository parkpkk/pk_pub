{
    "PBRMAP_NODE": {
        "desc": [
            "PBRMAP_NODE node related command"
        ],
        "output": {
            "desc": [
                "Direct vtysh output to file"
            ],
            "file": {
                "desc": [
                    "Direct vtysh output to file"
                ],
                "FILE": {
                    "desc": [
                        "Path to dump output to"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            }
        },
        "list": {
            "desc": [
                "Print command list"
            ],
            "permutations": {
                "desc": [
                    "Print all possible command permutations"
                ],
                "<cr>": {
                    "desc": [
                        "end_cmd"
                    ]
                }
            },
            "<cr>": {
                "desc": [
                    "end_cmd"
                ]
            }
        },
        "find": {
            "desc": [
                "Find CLI command matching a regular expression"
            ],
            "REGEX...": {
                "desc": [
                    "Search pattern (POSIX regex)"
                ],
                "<cr>": {
                    "desc": [
                        "end_cmd"
                    ]
                }
            }
        },
        "set": {
            "desc": [
                "Set for the PBR-MAP"
            ],
            "vrf": {
                "desc": [
                    "Specify the VRF for this map"
                ],
                "<NAME|unchanged>": {
                    "desc": [
                        "The VRF Name",
                        "Use the interface's VRF for lookup"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "nexthop-group": {
                "desc": [
                    "nexthop-group to use"
                ],
                "NHGNAME": {
                    "desc": [
                        "The name of the nexthop-group"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "vlan": {
                "desc": [
                    "Set action for VLAN tagging"
                ],
                "(1-4094)": {
                    "desc": [
                        "A valid value in range 1..4094"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "queue-id": {
                "desc": [
                    "Set based on egress port queue id"
                ],
                "(1-65535)": {
                    "desc": [
                        "A valid value in range 1..65535"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "pcp": {
                "desc": [
                    "Set based on 802.1p Priority Code Point (PCP) value"
                ],
                "(0-7)": {
                    "desc": [
                        "A valid value in range 0..7"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            }
        },
        "quit": {
            "desc": [
                "Exit current mode and down to previous mode"
            ],
            "<cr>": {
                "desc": [
                    "end_cmd"
                ]
            }
        },
        "exit": {
            "desc": [
                "Exit current mode and down to previous mode"
            ],
            "<cr>": {
                "desc": [
                    "end_cmd"
                ]
            }
        },
