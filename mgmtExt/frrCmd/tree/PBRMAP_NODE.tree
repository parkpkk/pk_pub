        },
        "match": {
            "desc": [
                "Match the rest of the command"
            ],
            "src-port": {
                "desc": [
                    "Choose the source port to use"
                ],
                "(1-65535)": {
                    "desc": [
                        "The Source Port"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "src-ip": {
                "desc": [
                    "Choose the src ip or ipv6 prefix to use"
                ],
                "<A.B.C.D/M|X:X::X:X/M>": {
                    "desc": [
                        "v4 Prefix",
                        "v6 Prefix"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "mark": {
                "desc": [
                    "Choose the mark value to use"
                ],
                "(1-4294967295)": {
                    "desc": [
                        "mark"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "ecn": {
                "desc": [
                    "Match based on IP ECN field"
                ],
                "(0-3)": {
                    "desc": [
                        "Explicit Congestion Notification"
                    ],
                    "<cr>": {
                        "desc": [
                            "end_cmd"
                        ]
                    }
                }
            },
            "dst-port": {
                "desc": [
                    "Choose the destination port to use"
                ],
                "(1-65535)": {
                    "desc": [
                        "The Destination Port"
                    ],
                    "<cr>": {
