                }
                leaf source-mac-mask {
                    type string;
                }
                leaf destination-mac {
                    type string;
                }
                leaf destination-mac-mask {
                    type string;
                }
                leaf ethertype {
                    type union {
                        type uint32 {
                            range "1536..65535";
                        }
                        type enumeration {
                            enum "ETHERTYPE_IPV4";
                            enum "ETHERTYPE_ARP";
                            enum "ETHERTYPE_VLAN";
                            enum "ETHERTYPE_IPV6";
                            enum "ETHERTYPE_MPLS";
