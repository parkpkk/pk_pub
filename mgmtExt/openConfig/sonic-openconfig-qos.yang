                    type enumeration {
                        enum "NORMAL";
                        enum "STUB";
                        enum "NSSA";
                    }
                }
                leaf name {
                    type string;
                }
            }
        }
        container INTERFACE_INPUT_CLASSIFIER_TERMS {
            list TERM {
