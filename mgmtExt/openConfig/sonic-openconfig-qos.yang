                leaf explicit-detail-match-mode {
                    type enumeration {
                        enum "ANY";
                        enum "ALL";
                    }
                }
                leaf builtin-detail {
                    type enumeration {
                        enum "TCP_INITIAL";
                        enum "TCP_ESTABLISHED";
                        enum "FRAGMENT";
                    }
                }
                leaf traffic-class {
                    type uint32 {
                        range "0..7";
                    }
                }
                leaf start-label-value {
                    type union {
                        type uint32 {
                            range "16..1048575";
                        }
                        type enumeration {
                            enum "IPV4_EXPLICIT_NULL";
                            enum "ROUTER_ALERT";
                            enum "IPV6_EXPLICIT_NULL";
                            enum "IMPLICIT_NULL";
                            enum "ENTROPY_LABEL_INDICATOR";
                            enum "NO_LABEL";
                        }
                    }
                }
                leaf end-label-value {
                    type union {
                        type uint32 {
                            range "16..1048575";
                        }
                        type enumeration {
                            enum "IPV4_EXPLICIT_NULL";
                            enum "ROUTER_ALERT";
                            enum "IPV6_EXPLICIT_NULL";
                            enum "IMPLICIT_NULL";
                            enum "ENTROPY_LABEL_INDICATOR";
                            enum "NO_LABEL";
                        }
                    }
                }
                leaf ttl-value {
                    type uint8;
                }
                leaf target-group {
                    type string;
                }
                leaf set-dscp {
                    type uint8;
                }
                leaf set-dot1p {
                    type uint8;
                }
                leaf set-mpls-tc {
                    type uint8;
                }
            }
        }
        container FORWARDING-GROUPS {
            list FORWARDING-GROUP {
