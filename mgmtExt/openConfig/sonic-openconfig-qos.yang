module sonic-openconfig-qos {
    namespace "http://github.com/sonic-net/openconfig/sonic-openconfig-qos";
    prefix sonic-openconfig-qos;
    yang-version 1.1;

    import ietf-inet-types {
        prefix inet;
    }

    organization
        "SONiC";

    contact
        "SONiC";

    description
        "SONIC OPENCONFIG YANG AUTO CONVERTION FOR OPENCONFIG-QOS";

    revision 2026-05-05 {
        description
            "Initial revision generated by YangIntegratedStandardizer.";
    }

    container sonic-openconfig-qos {
        container INTERFACES {
            list INTERFACE {
                key "interface-id";
                leaf interface-id {
                    type uint32;
                }
                leaf subinterface {
                    type uint64;
                }
                leaf buffer-allocation-profile {
                    type string;
                }
                leaf multicast-buffer-allocation-profile {
